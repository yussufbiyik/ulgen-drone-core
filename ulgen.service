[Unit]
Description=Drone Core Service
After=network.target

[Service]
# Run your wrapper script
ExecStart=%h/ulgen/drone-core/start_myservice.sh

# Ensure the service restarts if it crashes
Restart=always
RestartSec=5

# Run inside your project directory
WorkingDirectory=%h/ulgen/drone-core

# Log output into a file inside your home
StandardOutput=append:%h/ulgen/drone-core/drone-core.log
StandardError=append:%h/ulgen/drone-core/drone-core.log

[Install]
WantedBy=default.target
